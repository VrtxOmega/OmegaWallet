# ═══════════════════════════════════════════════════════════════
# OMEGA WALLET BACKEND — ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════

# Server
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# ─── RPC ENDPOINTS ────────────────────────────────────────────
# Use free or private RPC endpoints. Do NOT use public defaults
# in production — they rate-limit aggressively.
RPC_ETH=https://eth.llamarpc.com
RPC_BASE=https://mainnet.base.org
RPC_ARB=https://arb1.arbitrum.io/rpc
RPC_OP=https://mainnet.optimism.io

# ─── ERC-4337 BUNDLER ────────────────────────────────────────
# Get API keys from: stackup.sh, pimlico.io, or alchemy.com
BUNDLER_RPC_ETH=
BUNDLER_RPC_BASE=
BUNDLER_RPC_ARB=
BUNDLER_RPC_OP=

# ─── TOR/NYM PROXY ───────────────────────────────────────────
# Enable Tor: install Tor, set these values.
# Leave blank to disable Tor routing.
TOR_SOCKS_HOST=
TOR_SOCKS_PORT=9050

# Nym Mixnet (alternative to Tor)
NYM_GATEWAY=
